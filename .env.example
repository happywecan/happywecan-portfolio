# Copy this file to .env on each development machine.
# Do not commit real passwords.

# MongoDB connection string for local development.
# This can point to a local MongoDB, MongoDB Atlas, or a shared test server.
MONGODB_URI="mongodb://<MONGO_USER>:<MONGO_PASSWORD>@<MONGO_HOST>:27017/app_test?authSource=admin"

ADMIN_USER="angelo1016"
ADMIN_PASSWORD="<ADMIN_PASSWORD>"
SECRET_KEY="<SECRET_KEY>"

MAIL_USERNAME="<MAIL_USERNAME>"
MAIL_PASSWORD="<MAIL_PASSWORD>"
MAIL_SERVER="smtp.gmail.com"
MAIL_PORT="587"
MAIL_USE_TLS="True"

# Optional integrations.
AZURE_SPEECH_KEY="<AZURE_SPEECH_KEY>"
AZURE_SPEECH_REGION="<AZURE_SPEECH_REGION>"
GEMINI_API_KEY="<GEMINI_API_KEY>"

# Server-side tool integrations.
# Browser must never receive TOOLS_API_KEY directly.
TOOLS_API_BASE_URL="http://localhost:8010"
TOOLS_API_KEY="<TOOLS_API_KEY>"
